{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aster Bridge",
  "version": "0.4.12",
  "identifier": "com.astermail.bridge",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aster Bridge",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "maximized": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["aster-mail"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2QUQxN0IxRTVEMzQwRjEKUldUeFFOUGxzUmV0eHRuWHNDM1ZDZm9OTnZsU0I4R3JoYUFIeWtqcnV4eFEyN3VQdVRXNEdmajkK",
      "endpoints": [
        "https://github.com/Aster-Privacy/Aster-Bridge/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
